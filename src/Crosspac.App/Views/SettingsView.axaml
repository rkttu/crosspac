<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Crosspac.App.Views.SettingsView">

    <StackPanel Margin="16" Spacing="14" MaxWidth="720" HorizontalAlignment="Left">

        <TextBlock Text="pac executable" FontWeight="SemiBold" />
        <TextBlock Text="Leave as 'pac' to resolve it on your PATH, or point to a specific binary."
                   Foreground="#52606D" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox Text="{Binding PacPath}" Width="440" />
            <Button Content="Browse…" Command="{Binding BrowsePacCommand}" />
            <Button Content="Apply" Command="{Binding ApplyCommand}" Classes="accent" />
        </StackPanel>
        <TextBlock Text="{Binding Status}" Foreground="#0B7285" />

        <Border Height="1" Background="#E4E7EB" Margin="0,6" />

        <TextBlock Text="Settings file" FontWeight="SemiBold" />
        <SelectableTextBlock Text="{Binding SettingsFilePath}" Foreground="#52606D" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Open in default app" Command="{Binding OpenSettingsFileCommand}" />
        </StackPanel>
        <TextBlock Text="Window size is saved here automatically when you close the app."
                   Foreground="#52606D" TextWrapping="Wrap" />

    </StackPanel>

</UserControl>
