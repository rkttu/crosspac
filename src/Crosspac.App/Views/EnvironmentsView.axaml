<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Crosspac.App.Views.EnvironmentsView">

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            <Button Content="Select (set active)" Command="{Binding SelectCommand}" />
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="#52606D" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Environments}"
                  SelectedItem="{Binding SelectedEnvironment, Mode=TwoWay}"
                  DoubleTapped="OnRowDoubleTapped"
                  IsReadOnly="True" AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70" />
                <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="220" />
                <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*" />
                <DataGridTextColumn Header="Unique Name" Binding="{Binding UniqueName}" Width="200" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>

</UserControl>
