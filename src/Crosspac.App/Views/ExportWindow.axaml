<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Crosspac.App.Views.ExportWindow"
        Width="500" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Title="Export solution">

    <StackPanel Margin="20" Spacing="16">
        <TextBlock x:Name="Heading" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" />

        <StackPanel Spacing="6">
            <TextBlock Text="Destination" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="DestinationBox" Width="360" IsReadOnly="True"
                         Watermark="Choose a .zip file location…" />
                <Button Content="Browse…" Click="OnBrowse" />
            </StackPanel>
        </StackPanel>

        <CheckBox x:Name="AsyncCheck" Content="Export asynchronously (--async)" />

        <Expander Header="Advanced options">
            <StackPanel Spacing="10" Margin="0,8,0,0">
                <CheckBox x:Name="ManagedCheck" Content="Export as managed (--managed)" />
                <TextBlock Text="Managed exports locked components for test/production. Unchecked exports an editable, unmanaged solution."
                           Foreground="#627D98" TextWrapping="Wrap" />
                <CheckBox x:Name="OverwriteCheck" Content="Overwrite the destination file if it exists (--overwrite)" />
            </StackPanel>
        </Expander>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="OnCancel" MinWidth="80" />
            <Button x:Name="ExportButton" Content="Export" Click="OnExport" IsDefault="True"
                    MinWidth="80" IsEnabled="False" Classes="accent" />
        </StackPanel>
    </StackPanel>

</Window>
