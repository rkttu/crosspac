<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Crosspac.App.Views.CommandLogView">

    <DockPanel Background="#0B1620">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10"
                    Margin="10,6" VerticalAlignment="Center">
            <TextBlock Text="Command Log" FontWeight="Bold" Foreground="#CBD2D9"
                       VerticalAlignment="Center" />
            <Button Content="Clear" Command="{Binding ClearCommand}" />
        </StackPanel>

        <ScrollViewer Padding="10,0,10,8">
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding Time}" Foreground="#627D98"
                                       FontFamily="Cascadia Code,Menlo,Consolas,monospace" />
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                       Foreground="#E4E7EB"
                                       FontFamily="Cascadia Code,Menlo,Consolas,monospace" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</UserControl>
