<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Crosspac.App.Views.MainWindow"
        Width="{Binding WindowWidth, Mode=TwoWay}"
        Height="{Binding WindowHeight, Mode=TwoWay}"
        Title="Crosspac — Power Platform CLI">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1F2933" Padding="14,10">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Crosspac" FontWeight="Bold" FontSize="16"
                           Foreground="White" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PacStatus}" Foreground="#9FB3C8"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Active context status strip -->
        <Border DockPanel.Dock="Top" Background="#E4E7EB" Padding="14,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Active profile:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ActiveProfile}" VerticalAlignment="Center" />
                <TextBlock Text="   •   " Foreground="#9AA5B1" VerticalAlignment="Center" />
                <TextBlock Text="Active environment:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ActiveEnvironment}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Body: tabs on top, resizable shared command log on the bottom -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{Binding LogPanelHeight, Mode=TwoWay}" MinHeight="80" />
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0" Margin="4" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
                <TabItem Header="Auth">
                    <ContentControl Content="{Binding Auth}" />
                </TabItem>
                <TabItem Header="Environments">
                    <ContentControl Content="{Binding Environments}" />
                </TabItem>
                <TabItem Header="Solutions">
                    <ContentControl Content="{Binding Solutions}" />
                </TabItem>
                <TabItem Header="Settings">
                    <ContentControl Content="{Binding Settings}" />
                </TabItem>
            </TabControl>

            <!-- Modal busy overlay: blocks tab input while a query runs so a second one
                 can't be started, and hosts the cancel action for the running query. -->
            <Border Grid.Row="0" IsVisible="{Binding IsBusy}" Background="#99202A33">
                <Border Background="#1F2933" CornerRadius="10" Padding="28,22"
                        HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="240">
                    <StackPanel Spacing="16">
                        <TextBlock Text="{Binding BusyMessage}" Foreground="#E4E7EB"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" />
                        <ProgressBar IsIndeterminate="True" Width="200" />
                        <Button Content="Cancel" Command="{Binding CancelActiveCommand}"
                                HorizontalAlignment="Center" MinWidth="90" />
                    </StackPanel>
                </Border>
            </Border>

            <!-- Drag to resize the command log panel up/down -->
            <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                          ResizeDirection="Rows" Background="#334E68"
                          Cursor="SizeNorthSouth" />

            <Border Grid.Row="2" BorderBrush="#334E68" BorderThickness="0,1,0,0">
                <ContentControl Content="{Binding Log}" />
            </Border>
        </Grid>
    </DockPanel>

</Window>
