<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Crosspac.App.Views.MainWindow"
        Width="{Binding WindowWidth, Mode=TwoWay}"
        Height="{Binding WindowHeight, Mode=TwoWay}"
        Title="Crosspac — Power Platform CLI">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1F2933" Padding="14,10">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Crosspac" FontWeight="Bold" FontSize="16"
                           Foreground="White" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PacStatus}" Foreground="#9FB3C8"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Active context status strip -->
        <Border DockPanel.Dock="Top" Background="#E4E7EB" Padding="14,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Active profile:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ActiveProfile}" VerticalAlignment="Center" />
                <TextBlock Text="   •   " Foreground="#9AA5B1" VerticalAlignment="Center" />
                <TextBlock Text="Active environment:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ActiveEnvironment}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Body: tabs on top, shared command log on the bottom -->
        <Grid RowDefinitions="*,200">
            <TabControl Grid.Row="0" Margin="4">
                <TabItem Header="Auth">
                    <ContentControl Content="{Binding Auth}" />
                </TabItem>
                <TabItem Header="Environments">
                    <ContentControl Content="{Binding Environments}" />
                </TabItem>
                <TabItem Header="Solutions">
                    <ContentControl Content="{Binding Solutions}" />
                </TabItem>
                <TabItem Header="Settings">
                    <ContentControl Content="{Binding Settings}" />
                </TabItem>
            </TabControl>

            <Border Grid.Row="1" BorderBrush="#334E68" BorderThickness="0,1,0,0">
                <ContentControl Content="{Binding Log}" />
            </Border>
        </Grid>
    </DockPanel>

</Window>
