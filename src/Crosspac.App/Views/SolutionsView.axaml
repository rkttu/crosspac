<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Crosspac.App.Views.SolutionsView">

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                <Button Content="Export…" Command="{Binding ExportCommand}" />
                <Button Content="Import…" Command="{Binding ImportCommand}" />
                <Button Content="Publish…" Command="{Binding PublishCommand}" />
                <Button Content="Delete…" Command="{Binding DeleteCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="#52606D" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Solutions}"
                  SelectedItem="{Binding SelectedSolution, Mode=TwoWay}"
                  IsReadOnly="True" AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Unique Name" Binding="{Binding UniqueName}" Width="240" />
                <DataGridTextColumn Header="Friendly Name" Binding="{Binding FriendlyName}" Width="*" />
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="120" />
                <DataGridCheckBoxColumn Header="Managed" Binding="{Binding IsManaged}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>

</UserControl>
